{
  "name": "sunny-furniture-commerce",
  "version": "1.0.0",
  "description": "Production MVP e-commerce platform for Sunny Furniture",
  "private": true,
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "dev:memory": "node backend/scripts/devWithMemoryDb.js",
    "seed": "node backend/scripts/seedCatalog.js",
    "test": "cross-env NODE_ENV=test jest --runInBand",
    "admin:install": "npm install --prefix admin",
    "admin:build": "npm run build --prefix admin",
    "heroku-postbuild": "npm run admin:install && npm run admin:build"
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.1.2",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.5.0",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.6",
    "razorpay": "^2.9.6",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^30.2.0",
    "mongodb-memory-server": "^10.4.1",
    "nodemon": "^3.1.14",
    "supertest": "^7.1.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/backend/tests/**/*.test.js"
    ]
  }
}
